generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  nickname  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  onboardingCompleted Boolean @default(false)

  coupleId String?
  couple   Couple? @relation("CoupleMembers", fields: [coupleId], references: [id])

  bankConnections   BankConnection[]
  transactionsOwned Transaction[]
  invitesSent       CoupleInvite[]   @relation("InviteSender")
  categories        Category[]
  splitRules        SplitRule[]

  @@map("users")
}

model Couple {
  id         String   @id @default(cuid())
  closingDay Int      @default(5) // day of month when credit card cycle closes
  user1Id    String?  // ID do primeiro membro (quem criou o casal)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members          User[]         @relation("CoupleMembers")
  splitRules       SplitRule[]
  monthlySummaries MonthlySummary[]
  invites          CoupleInvite[]

  @@map("couples")
}

model CoupleInvite {
  id        String           @id @default(cuid())
  token     String           @unique @default(cuid())
  status    InviteStatus     @default(PENDING)
  expiresAt DateTime
  createdAt DateTime         @default(now())

  coupleId String
  couple   Couple @relation(fields: [coupleId], references: [id])

  senderId String
  sender   User   @relation("InviteSender", fields: [senderId], references: [id])

  @@map("couple_invites")
}

model BankConnection {
  id           String               @id @default(cuid())
  pluggyItemId String               @unique
  bankName     String
  nickname     String?              // user-defined display name (overrides bankName in UI)
  bankLogo     String?
  accountType  AccountType          @default(PERSONAL)
  isCreditCard Boolean              @default(false)
  isManual     Boolean              @default(false)
  status       BankConnectionStatus @default(ACTIVE)
  lastSyncAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@map("bank_connections")
}

model Transaction {
  id            String          @id @default(cuid())
  pluggyTxId    String?         @unique
  date          DateTime        // original transaction date from bank
  billingMonth  String?         // YYYY-MM — which month this counts toward (credit card logic)
  description   String          // original name from bank
  customName    String?         // user-defined name (e.g. "Disco do Pink Floyd 4/5")
  amount        Decimal         @db.Decimal(12, 2)
  category      String?
  isShared      Boolean         @default(true)
  isCreditCard  Boolean         @default(false)
  pendingReview Boolean         @default(false)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  bankConnectionId String
  bankConnection   BankConnection @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)

  ownerUserId String
  owner       User   @relation(fields: [ownerUserId], references: [id])

  split TransactionSplit?

  @@map("transactions")
}

model SplitRule {
  id         String         @id @default(cuid())
  name       String
  matchField SplitMatchField
  matchValue String
  pctUser1   Decimal        @db.Decimal(5, 2)
  pctUser2   Decimal        @db.Decimal(5, 2)
  priority   Int            @default(0)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  coupleId String?
  couple   Couple? @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  appliedToSplits TransactionSplit[]

  @@map("split_rules")
}

model TransactionSplit {
  id               String   @id @default(cuid())
  pctUser1         Decimal  @db.Decimal(5, 2)
  pctUser2         Decimal  @db.Decimal(5, 2)
  amountUser1      Decimal  @db.Decimal(12, 2)
  amountUser2      Decimal  @db.Decimal(12, 2)
  isManualOverride Boolean  @default(false)
  appliedRuleId    String?
  appliedRule      SplitRule? @relation(fields: [appliedRuleId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_splits")
}

model MonthlySummary {
  id           String    @id @default(cuid())
  month        String    // YYYY-MM
  totalUser1   Decimal   @db.Decimal(12, 2)
  totalUser2   Decimal   @db.Decimal(12, 2)
  balance      Decimal   @db.Decimal(12, 2) // positive = user1 owes user2, negative = user2 owes user1
  settledAt    DateTime?
  settledNote  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  coupleId String
  couple   Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@unique([coupleId, month])
  @@map("monthly_summaries")
}

enum AccountType {
  SHARED
  PERSONAL
}

enum BankConnectionStatus {
  ACTIVE
  ERROR
  DISCONNECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Category {
  id        String   @id @default(cuid())
  name      String
  icon      String?  // emoji
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("categories")
}

enum SplitMatchField {
  CATEGORY
  DESCRIPTION
  ACCOUNT_TYPE
}
